<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- The extension works on Android TV (NVIDIA Shield) but is deliberately
         launcher-less there: it is enabled entirely inside SeriesGuide, so there is
         nothing to "open" from the TV home screen. required=false keeps the app
         installable on TVs without restricting it to them. -->
    <uses-feature
        android:name="android.software.leanback"
        android:required="false" />
    <uses-feature
        android:name="android.hardware.touchscreen"
        android:required="false" />

    <!-- TMDb fallback lookups + GitHub release check -->
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- JobIntentService compatibility path on API 23-25 -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- Android 11+ package visibility for the apps we detect and launch. The intent
         entry keeps stremio:// links resolvable even if Stremio ever changes its
         application id. -->
    <queries>
        <package android:name="com.battlelancer.seriesguide" />
        <package android:name="com.uwetrottmann.seriesguide.amzn" />
        <package android:name="com.stremio.one" />
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="stremio" />
        </intent>
    </queries>

    <!-- Backup stays on for the IMDb-id cache, but the SeriesGuide pairing token is
         excluded: a restored stale token makes SeriesGuide silently ignore every
         action this extension publishes. -->
    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.OpenInStremio"
        tools:targetApi="s">
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Trampoline for the SeriesGuide action's view intent. Exported so SeriesGuide
             can start it, but with no intent filter it is only reachable by explicit
             component. Task hygiene keeps it out of Recents and off SeriesGuide's task. -->
        <activity
            android:name=".forwarder.StremioLaunchActivity"
            android:exported="true"
            android:excludeFromRecents="true"
            android:noHistory="true"
            android:taskAffinity=""
            android:theme="@style/Theme.OpenInStremio.Forwarder" />

        <!-- SeriesGuide discovers extensions through this receiver. The SUBSCRIBE and
             UPDATE actions are required for Android 15 (SDK 35) safer intents; without
             them the receiver stops getting subscribe/update broadcasts. -->
        <receiver
            android:name=".extension.OpenInStremioExtensionReceiver"
            android:description="@string/extension_description"
            android:exported="true"
            android:label="@string/extension_name">
            <intent-filter>
                <action android:name="com.battlelancer.seriesguide.api.SeriesGuideExtension" />
                <action android:name="com.battlelancer.seriesguide.api.action.SUBSCRIBE" />
                <action android:name="com.battlelancer.seriesguide.api.action.UPDATE" />
            </intent-filter>
            <!-- Lets SeriesGuide's Extensions screen open this app's own UI (the only way
                 to reach it on Android TV, where the app has no launcher icon). SeriesGuide
                 prepends "<package>/" itself before unflattening, so this must be the bare
                 class name - a package-prefixed value breaks with ActivityNotFoundException. -->
            <meta-data
                android:name="settingsActivity"
                android:value=".MainActivity" />
        </receiver>

        <!-- Worker service behind the receiver; SeriesGuideExtension is a JobIntentService,
             so the system binds it with the job-service permission. -->
        <service
            android:name=".extension.OpenInStremioExtension"
            android:exported="false"
            android:permission="android.permission.BIND_JOB_SERVICE" />
    </application>

</manifest>
