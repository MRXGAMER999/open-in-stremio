<?xml version="1.0" encoding="utf-8"?><!--
   Applies to API 31+ (android:dataExtractionRules). The seriesguide-api base class
   stores the SeriesGuide subscriber pairing (component|token) in this prefs file.
   Restoring a stale token after reinstall/transfer makes SeriesGuide silently drop
   every published action; an absent file is repopulated by SeriesGuide's next
   SUBSCRIBE broadcast, so it must never be backed up or transferred.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude
            domain="sharedpref"
            path="seriesguideextension_OpenInStremioExtension.xml" />
    </cloud-backup>
    <device-transfer>
        <exclude
            domain="sharedpref"
            path="seriesguideextension_OpenInStremioExtension.xml" />
    </device-transfer>
</data-extraction-rules>
