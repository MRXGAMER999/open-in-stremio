<?xml version="1.0" encoding="utf-8"?><!--
   Applies to API 23-30 (android:fullBackupContent). The seriesguide-api base class
   stores the SeriesGuide subscriber pairing (component|token) in this prefs file.
   Restoring a stale token after reinstall/transfer makes SeriesGuide silently drop
   every published action; an absent file is repopulated by SeriesGuide's next
   SUBSCRIBE broadcast, so it must never be backed up.
-->
<full-backup-content>
    <exclude
        domain="sharedpref"
        path="seriesguideextension_OpenInStremioExtension.xml" />
</full-backup-content>
